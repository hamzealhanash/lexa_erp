{
  "name": "lexa-erp",
  "productName": "Lexa ERP",
  "private": true,
  "version": "0.1.2",
  "description": "Lexa ERP - A desktop enterprise resource planning application",
  "author": "hamze",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development vite",
    "build": "vite build && pnpm run copy:assets",
    "copy:assets": "node -e \"const fs=require('fs'); fs.mkdirSync('dist/electron/services/printer/resources', {recursive:true}); fs.cpSync('src/electron/services/printer/resources', 'dist/electron/services/printer/resources', {recursive:true, force:true})\"",
    "build:mac": "pnpm build && electron-builder --mac --arm64",
    "build:win": "pnpm build && electron-builder --win --x64",
    "build:linux": "pnpm build && electron-builder --linux --x64",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/noto-sans-arabic": "^5.2.10",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-pos-printer": "^1.3.8",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vite-plugin-electron": "^0.29.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "cross-env": "^10.1.0",
    "electron": "^40.8.5",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2"
  },
  "onlyBuiltDependencies": [
    "electron",
    "better-sqlite3",
    "better-sqlite3-multiple-ciphers",
    "esbuild",
    "electron-winstaller",
    "msw"
  ]
}