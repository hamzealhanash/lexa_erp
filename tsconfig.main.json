{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@types": [
        "./src/global-types.d.ts"
      ],
      "@src/*": [
        "./src/*"
      ],
      "@services/*": [
        "./src/electron/services/*"
      ],
      "@electron/*": [
        "./src/electron/*"
      ]
    }
  },
  "include": [
    "src/electron/**/*"
  ],
  "exclude": [
    "node_modules",
    "src/frontend"
  ]
}